@using SocOps.Models

<button
    @onclick="OnClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses()"
    style="@GetAnimStyle()"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="wrap-break-word hyphens-auto">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="sq-stamp">&#9679;</span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var baseClasses = "relative flex items-center justify-center p-1 text-center border rounded transition-all duration-150 select-none min-h-[60px] text-xs leading-tight";

        string stateClasses;
        if (Square.IsFreeSpace)
            stateClasses = IsWinning ? "sq-winning font-bold" : "sq-free font-bold";
        else if (Square.IsMarked)
            stateClasses = IsWinning ? "sq-winning" : "sq-marked";
        else
            stateClasses = "sq-unmarked";

        return $"{baseClasses} {stateClasses}";
    }

    private string GetAnimStyle()
    {
        return $"animation: board-fade-in 0.3s ease-out both; animation-delay: {Square.Id * 30}ms;";
    }
}

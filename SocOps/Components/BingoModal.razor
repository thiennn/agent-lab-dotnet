<div class="modal-overlay">
    <div class="modal-card">
        <div class="mission-complete-text">Mission<br />Complete</div>
        <div class="mission-subtext">Objective achieved &mdash; line confirmed</div>
        <button @onclick="OnDismiss" class="continue-button">
            Continue Operation
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}

<div class="flex flex-col min-h-full bg-gray-50">

    <div class="classify-bar">&#9632; classification: top secret &#9632;</div>

    <div class="flex flex-col items-center justify-center flex-1 p-6">
        <div style="max-width: 22rem; width: 100%;">

            <div class="text-center mb-8">
                <h1 style="font-family: 'Special Elite', cursive; font-size: 3.5rem; line-height: 1; color: var(--col-text); letter-spacing: -0.01em; margin: 0 0 0.5rem;">
                    SOC OPS
                </h1>
                <p style="font-family: 'Courier Prime', monospace; font-size: 0.68rem; letter-spacing: 0.22em; color: var(--col-muted); text-transform: uppercase; margin: 0;">
                    // Social Operations Unit //
                </p>
            </div>

            <div class="mission-brief-card">
                <div class="brief-header">&#9650; Mission Brief &#9650;</div>
                <ul class="mission-rules">
                    <li><span style="color: var(--col-red); font-weight: bold;">01.</span> Locate personnel matching listed criteria</li>
                    <li><span style="color: var(--col-red); font-weight: bold;">02.</span> Tap square to confirm target acquisition</li>
                    <li><span style="color: var(--col-red); font-weight: bold;">03.</span> Secure 5 in a row to complete mission</li>
                </ul>
            </div>

            <button @onclick="OnStart" class="deploy-button">
                Deploy Agent &#8594;
            </button>

        </div>
    </div>

    <div class="classify-bar">&#9632; clearance required &#9632;</div>

</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
